@page
@{
    ViewData["Title"] = "Perfumadores - MALP";
}

<style>
    /* Cinta animada */
    .contenedor-cinta {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background-color: #1b5e20;
        color: white;
        overflow: hidden;
        white-space: nowrap;
        padding: 12px 0;
        z-index: 5000;
    }

    .texto-animado {
        display: inline-block;
        padding-left: 100%;
        animation: marquee 20s linear infinite;
        font-weight: bold;
        text-transform: uppercase;
    }

    @@keyframes marquee {
        0% {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(-100%, 0);
        }
    }

    body {
        padding-top: 70px;
        background-color: #fdfaf5;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* Botón flotante Subir */
    #btnSubir {
        display: none;
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 5500;
        border: none;
        outline: none;
        background-color: #1b5e20;
        color: white;
        cursor: pointer;
        padding: 15px;
        border-radius: 50%;
        font-size: 20px;
        width: 50px;
        height: 50px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        #btnSubir:hover {
            background-color: #2e7d32;
            transform: scale(1.1);
        }

    .seccion-titulo {
        color: #1b5e20;
        text-align: center;
        margin: 40px 0 20px 0;
        font-size: 2rem;
        border-bottom: 2px solid #1b5e20;
        display: inline-block;
        width: 100%;
        padding-bottom: 10px;
    }

    .tarjeta-producto {
        border-radius: 15px;
        padding: 20px;
        width: 300px;
        text-align: center;
        background-color: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .reseña-visible {
        font-size: 0.9rem;
        color: #555;
        font-style: italic;
        margin: 10px 0;
        min-height: 50px;
    }

    .caja-precios-sensorial {
        background-color: #f5f5dc;
        border: 1px solid #d2b48c;
        border-radius: 10px;
        padding: 12px;
        margin: 15px 0;
    }

    .btn-principal {
        background-color: #1b5e20 !important;
        color: white !important;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-principal:hover {
            background-color: #2e7d32 !important;
            transform: scale(1.02);
        }

    .btn-volver-final {
        display: block;
        width: 250px;
        margin: 50px auto 20px auto;
        padding: 15px;
        background-color: #000000;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        border-radius: 8px;
        transition: 0.3s;
    }

    #visorFotos {
        display: none;
        position: fixed;
        z-index: 6000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.98);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    #imgVisor {
        max-width: 80%;
        max-height: 50%;
        border-radius: 15px;
    }
</style>

<button onclick="subirArriba()" id="btnSubir" title="Subir al inicio">▲</button>

<div class="contenedor-cinta">
    <div class="texto-animado">
        AMBIENTES SIEMPRE FRESCOS — M A L P — PRODUCTOS ELABORADOS CON DEDICACIÓN 🌿
    </div>
</div>

<div id="contenidoPrincipal" style="padding: 20px; max-width: 1200px; margin: 30px auto 0 auto;">

    <div style="text-align: center; margin-bottom: 20px;">
        <img src="/Images/logo1.webp" alt="Logotipo de MALP" style="width: 180px;" />
    </div>

    <h1 class="seccion-titulo">Perfumadores de Ambiente y Ropa (100ml)</h1>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; margin-bottom: 50px;">
        @{
            var listaHogar = new[] {
                new { id = "pino", n = "Pino", c = "#e8f5e9", img = "Pino.png", r = "Fragancia silvestre y vigorizante que trae la frescura pura del bosque." },
                new { id = "chicle", n = "Chicle", c = "#fce4ec", img = "Chicle.png", r = "Aroma dulce, divertido y nostálgico que encanta en cualquier rincón." },
                new { id = "ropalimpia", n = "Ropa Limpia", c = "#e3f2fd", img = "Ropa Limpia.png", r = "Sensación de frescura recién lavada, ideal para sábanas y cortinas." },
                new { id = "lavandarelax", n = "Lavanda Relax", c = "#f3e5f5", img = "Lavanda Relax.png", r = "Calma y equilibrio; perfecta para rociar antes de dormir." }
                };

            foreach (var item in listaHogar)
            {
                <section class="tarjeta-producto" style="border: 2px solid @item.c;">
                    <button type="button" onclick="abrirVisor('@item.img', '@item.n', '@item.r')" style="border:none; background:none; cursor:pointer; padding:0;">
                        <div style="height: 180px; margin-bottom: 15px; background-color: #f9f9f9; border-radius: 8px; overflow: hidden;">
                            <img src="/Images/@item.img" alt="Envase @item.n" style="width: 100%; height: 100%; object-fit: contain;" />
                        </div>
                    </button>
                    <h3 style="font-size: 1.4rem; color: #1b5e20;">@item.n</h3>
                    <div class="reseña-visible">@item.r</div>
                    <div class="caja-precios-sensorial">
                        <span style="font-weight: bold; color: #5d4037;">100ml - UYU 290</span>
                    </div>
                    <button type="button" class="btn-principal" onclick="agregarAlCarrito('Perfumador @item.n (100ml)', 290, '@item.img')">
                        Agregar al Carrito
                    </button>
                </section>
            }
        }
    </div>

    <h2 class="seccion-titulo">Perfumadores para Auto</h2>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px;">
        @{
            var listaAuto = new[] {
                new { id = "auto_mango", n = "Mango", c = "#fff3e0", img = "perfumador de auto mango.png", r = "Energía frutal y tropical para que cada viaje sea refrescante." },
                new { id = "auto_dama", n = "Dama de la Noche", c = "#ede7f6", img = "perfumador de auto dama de la noche.png", r = "Elegancia y misterio en un aroma intenso para tu vehículo." },
                new { id = "auto_melon", n = "Melón Dulce", c = "#e8f5e9", img = "perfumador de auto melon dulce.png", r = "Dulzura vibrante y veraniega que alegra tus trayectos." }
                };

            foreach (var item in listaAuto)
            {
                <section class="tarjeta-producto" style="border: 2px solid @item.c;">
                    <button type="button" onclick="abrirVisor('@item.img', '@item.n', '@item.r')" style="border:none; background:none; cursor:pointer; padding:0;">
                        <div style="height: 180px; margin-bottom: 15px; background-color: #f9f9f9; border-radius: 8px; overflow: hidden;">
                            <img src="/Images/@item.img" alt="Auto @item.n" style="width: 100%; height: 100%; object-fit: contain;" />
                        </div>
                    </button>
                    <h3 style="font-size: 1.4rem; color: #1b5e20;">@item.n (Auto)</h3>
                    <div class="reseña-visible">@item.r</div>
                    <div class="caja-precios-sensorial">
                        <span style="font-weight: bold; color: #5d4037;">Precio: UYU 150</span>
                    </div>
                    <button type="button" class="btn-principal" onclick="agregarAlCarrito('Perfumador Auto @item.n', 150, '@item.img')">
                        Agregar al Carrito
                    </button>
                </section>
            }
        }
    </div>

    <a href="/#catalogo" class="btn-volver-final">Volver al Catálogo</a>
</div>

<div id="visorFotos" role="dialog" aria-modal="true" onclick="if(event.target == this) cerrarVisor()">
    <button type="button" onclick="cerrarVisor()" style="position: absolute; top: 20px; right: 30px; font-size: 30px; cursor:pointer; background:none; border:none; color:#1b5e20;">✕</button>
    <img id="imgVisor" src="" alt="Imagen ampliada">
    <div id="resenaFragancia" style="color: #1b5e20; font-size: 1.3rem; margin-top: 20px; max-width: 80%; font-weight: 500; text-align: center;"></div>
</div>

<script>
    // --- LÓGICA DEL CARRITO ---
    function agregarAlCarrito(nombre, precio, imagen) {
        let carrito = JSON.parse(localStorage.getItem('carritoMALP')) || [];
        carrito.push({ nombre: nombre, precio: precio, imagen: imagen });
        localStorage.setItem('carritoMALP', JSON.stringify(carrito));

        if (typeof actualizarContador === 'function') {
            actualizarContador();
        }

        alert("¡" + nombre + " agregado al carrito!");
    }

    window.onscroll = function() {
        const btn = document.getElementById("btnSubir");
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btn.style.display = "block";
        } else {
            btn.style.display = "none";
        }
    };

    function subirArriba() {
        window.scrollTo({top: 0, behavior: 'smooth'});
    }

    function abrirVisor(imgSrc, nombre, resena) {
        document.getElementById("imgVisor").src = "/Images/" + imgSrc;
        document.getElementById("imgVisor").alt = "Foto de " + nombre;
        document.getElementById("resenaFragancia").innerText = resena;
        document.getElementById("visorFotos").style.display = "flex";
    }

    function cerrarVisor() {
        document.getElementById("visorFotos").style.display = "none";
    }
</script>