@page
@{
    ViewData["Title"] = "Eco Desodorantes - MALP";
}

<style>
    /* Cinta animada */
    .contenedor-cinta {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background-color: #1b5e20;
        color: white;
        overflow: hidden;
        white-space: nowrap;
        padding: 12px 0;
        z-index: 5000;
    }

    .texto-animado {
        display: inline-block;
        padding-left: 100%;
        animation: marquee 20s linear infinite;
        font-weight: bold;
        text-transform: uppercase;
    }

    @@keyframes marquee {
        0% {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(-100%, 0);
        }
    }

    body {
        padding-top: 80px;
        background-color: #fdfaf5;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* Botón flotante Subir */
    #btnSubir {
        display: none;
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 5500;
        border: none;
        outline: none;
        background-color: #1b5e20;
        color: white;
        cursor: pointer;
        padding: 15px;
        border-radius: 50%;
        font-size: 20px;
        width: 50px;
        height: 50px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        #btnSubir:hover {
            background-color: #2e7d32;
            transform: scale(1.1);
        }

    .tarjeta-producto {
        border-radius: 15px;
        padding: 20px;
        width: 340px;
        text-align: center;
        background-color: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        border: 2px solid #e0e0e0;
        justify-content: space-between;
    }

    .contenedor-foto {
        height: 200px;
        margin-bottom: 15px;
        background-color: #f9f9f9;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        border: none;
        width: 100%;
        padding: 0;
    }

        .contenedor-foto img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .descripcion-visible {
        font-size: 0.95rem;
        color: #444;
        line-height: 1.4;
        margin: 10px 0 15px 0;
        text-align: center;
        min-height: 80px;
    }

    .duracion-badge {
        display: inline-block;
        background-color: #e8f5e9;
        color: #2e7d32;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .btn-compra {
        background-color: #1b5e20 !important;
        color: white !important;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
        font-size: 1rem;
        margin-top: 8px;
        transition: 0.3s;
    }

        .btn-compra:hover {
            background-color: #2e7d32 !important;
            transform: scale(1.02);
        }

    .btn-volver-final {
        display: block;
        width: 220px;
        margin: 40px auto;
        padding: 15px;
        background-color: #000000;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        border-radius: 8px;
        transition: 0.3s;
    }

    #visorFotos {
        display: none;
        position: fixed;
        z-index: 6000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.98);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    #imgVisor {
        max-width: 80%;
        max-height: 60%;
        border-radius: 15px;
        border: 2px solid #1b5e20;
    }
</style>

<button onclick="subirArriba()" id="btnSubir" title="Subir al inicio">▲</button>

<main id="contenidoPrincipal">
    <div class="contenedor-cinta">
        <div class="texto-animado">
            🌿 ECO DESODORANTES MALP: ACEITES ESENCIALES Y VITAMINA E — PROTECCIÓN NATURAL SIN ALUMINIO 🚚
        </div>
    </div>

    <div style="text-align: center; margin-top: 20px;">
        <img src="/Images/logo1.webp" alt="Logotipo de MALP" style="width: 180px;" />
        <h1 style="color: #1b5e20; margin-top: 20px;">Eco Desodorantes Naturales</h1>
    </div>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; padding: 20px;">
        @{
            var listaEco = new[] {
                new { id = "eco_lavanda", n = "Lavanda", descCorta = "Aceites esenciales de Lavanda, Árbol del Té y Vitamina E.", beneficios = "Antibacterial, calma la piel sensible y brinda un aroma relajante.", img = "eco lavanda.png" },
                new { id = "eco_bergamota", n = "Bergamota", descCorta = "Aceites esenciales de Bergamota, Árbol del Té y Vitamina E.", beneficios = "Neutraliza olores de forma cítrica y refrescante, aportando energía.", img = "eco bergamota.png" },
                new { id = "eco_menta", n = "Menta", descCorta = "Aceites esenciales de Menta, Árbol del Té y Vitamina E.", beneficios = "Brinda máxima frescura y limpieza profunda, ideal para actividad física.", img = "eco menta.png" }
                };

            foreach (var item in listaEco)
            {
                <section class="tarjeta-producto">
                    <button type="button" class="contenedor-foto" onclick="abrirVisor('@item.id')" aria-label="Ver fotos de @item.n">
                        <img src="/Images/@item.img" alt="Foto de @item.n" />
                    </button>

                    <h3 style="color: #1b5e20; margin: 0;">Eco @item.n</h3>

                    <div class="descripcion-visible">
                        <strong>@item.descCorta</strong><br>
                        <span>@item.beneficios</span>
                    </div>

                    <div class="duracion-badge">
                        ⏱️ Duración: ~3 meses
                    </div>

                    <button type="button" class="btn-compra"
                            onclick="gestionarCarrito('agregar', 'Eco Desodorante @item.n (50ml)', 600, '@item.img')">
                        50ml - UYU 600
                    </button>

                    <button type="button" class="btn-compra"
                            onclick="gestionarCarrito('agregar', 'Eco Desodorante @item.n (30ml)', 450, '@item.img')">
                        30ml - UYU 450
                    </button>
                </section>
            }
        }
    </div>

    <a href="/#catalogo" class="btn-volver-final">Volver al Catálogo</a>
</main>

<div id="visorFotos" role="dialog" aria-modal="true" onclick="if(event.target == this) cerrarVisor()">
    <button type="button" onclick="cerrarVisor()" style="position: absolute; top: 20px; right: 30px; font-size: 40px; border:none; background:none; color:#1b5e20; cursor:pointer;">✕</button>
    <img id="imgVisor" src="" alt="Foto ampliada">
    <p id="resenaVisor" style="color: #1b5e20; font-weight: bold; margin-top: 20px; font-size: 1.2rem; padding: 0 20px; text-align: center;"></p>
</div>

<script>
    function gestionarCarrito(accion, nombre, precio, imagen) {
        if (accion === 'agregar') {
            let carrito = JSON.parse(localStorage.getItem('carritoMALP')) || [];
            carrito.push({ nombre: nombre, precio: precio, imagen: imagen });
            localStorage.setItem('carritoMALP', JSON.stringify(carrito));

            if (typeof actualizarContador === 'function') {
                actualizarContador();
            }

            // CAMBIO AQUÍ: Alert ahora muestra UYU
            alert("¡" + nombre + " agregado al carrito por UYU " + precio + "!");
        }
    }

    window.onscroll = function() {
        const btn = document.getElementById("btnSubir");
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btn.style.display = "block";
        } else {
            btn.style.display = "none";
        }
    };

    function subirArriba() {
        window.scrollTo({top: 0, behavior: 'smooth'});
    }

    const datos = {
        eco_lavanda: { f: "/Images/eco lavanda.png", r: "Eco Lavanda: Lavanda, Árbol del Té y Vitamina E." },
        eco_bergamota: { f: "/Images/eco bergamota.png", r: "Eco Bergamota: Bergamota, Árbol del Té y Vitamina E." },
        eco_menta: { f: "/Images/eco menta.png", r: "Eco Menta: Menta, Árbol del Té y Vitamina E." }
    };

    function abrirVisor(id) {
        document.getElementById("imgVisor").src = datos[id].f;
        document.getElementById("resenaVisor").innerText = datos[id].r;
        document.getElementById("visorFotos").style.display = "flex";
    }

    function cerrarVisor() {
        document.getElementById("visorFotos").style.display = "none";
    }
</script>