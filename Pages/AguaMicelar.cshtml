@page
@{
    ViewData["Title"] = "Agua Micelar Botánica - MALP";
}

<style>
    body {
        padding-top: 90px;
        background-color: #fcf9f2;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #333;
    }

    .contenedor-producto {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .tarjeta-detalles {
        background-color: #ffffff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        border-top: 6px solid #1b5e20;
    }

    .seccion-flex {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        align-items: center;
    }

    .caja-foto {
        flex: 1;
        min-width: 280px;
        height: 300px;
        background-color: #f9f9f9;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2ddd5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .caja-info {
        flex: 1.2;
        min-width: 280px;
    }

    .precio-destacado {
        font-size: 1.8rem;
        color: #1b5e20;
        font-weight: bold;
        margin: 15px 0;
    }

    .propiedades-lista {
        list-style: none;
        padding: 0;
        margin: 20px 0;
    }

        .propiedades-lista li {
            margin-bottom: 10px;
            padding-left: 25px;
            position: relative;
        }

            .propiedades-lista li::before {
                content: "✨";
                position: absolute;
                left: 0;
                top: 0;
            }

    .btn-comprar {
        background-color: #1b5e20;
        color: white !important;
        border: none;
        padding: 14px 28px;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        width: 100%;
        transition: 0.3s;
    }

        .btn-comprar:hover {
            background-color: #2e7d32;
        }

    .btn-volver {
        display: block;
        width: 200px;
        margin: 20px auto;
        padding: 10px;
        background-color: #000000;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        border-radius: 8px;
        transition: 0.3s;
    }
</style>

<div class="contenedor-producto">
    <div class="tarjeta-detalles">
        <div class="seccion-flex">
            
            <div class="caja-foto">
                <img src="/Images/agua_micelar.webp" alt="Agua Micelar MALP" style="width: 100%; height: 100%; object-fit: contain;" onerror="this.src='/Images/logo1.webp'" />
            </div>

            <div class="caja-info">
                <span style="color: #d2b48c; font-weight: bold; text-transform: uppercase; font-size: 0.9rem;">Línea Facial Natural</span>
                <h1 style="color: #1b5e20; margin: 5px 0 15px 0; font-size: 2rem;">Agua Micelar Botánica</h1>
                
                <p style="font-size: 1.1rem; line-height: 1.6; color: #555;">
                    Una solución de limpieza facial suave e inteligente basada en micelas botánicas. Atrapa las impurezas, rastros de contaminación y maquillaje sin necesidad de frotar fuertemente ni resecar la piel.
                </p>

                <div class="precio-destacado">UYU 520</div>

                <button type="button" class="btn-comprar" onclick="agregarAlCarrito('Agua Micelar Botánica', 220, 'agua_micelar.webp')">
                    Agregar al Carrito
                </button>
            </div>

        </div>

        <div style="margin-top: 40px; border-top: 1px solid #f5f5dc; padding-top: 25px;">
            <h3 style="color: #1b5e20; font-size: 1.3rem;">Acción 3 en 1</h3>
            <ul class="propiedades-lista">
                <li><strong>Limpia profundamente:</strong> Despeja los poros de grasitud y suciedad acumulada a lo largo del día.</li>
                <li><strong>Desmaquilla con suavidad:</strong> Ideal incluso para zonas sensibles como el contorno de ojos y labios.</li>
                <li><strong>Tonifica e Hidrata:</strong> Al ser de base herbal natural, deja la piel fresca, calmada y lista para tu crema de noche o pomada MALP. Sin sensación pegajosa.</li>
            </ul>
        </div>
    </div>

    <a href="/" class="btn-volver">Volver al Catálogo</a>
</div>

<script>
    function agregarAlCarrito(nombre, precio, imagen) {
        let carrito = JSON.parse(localStorage.getItem('carritoMALP')) || [];
        carrito.push({
            nombre: nombre,
            precio: parseInt(precio),
            imagen: imagen
        });
        localStorage.setItem('carritoMALP', JSON.stringify(carrito));

        if (typeof actualizarContador === 'function') {
            actualizarContador();
        }

        alert(`¡${nombre} agregado al carrito con éxito!`);
    }
</script>