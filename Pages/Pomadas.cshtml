@page "/Pomadas"
@{
    ViewData["Title"] = "Pomadas MALP - Próximamente";
}

<style>
    .lanzamiento-container {
        max-width: 800px;
        margin: auto;
        padding: 100px 20px;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .badge-laboratorio {
        background-color: var(--verde-malp);
        color: white;
        padding: 8px 25px;
        border-radius: 4px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.85rem;
    }

    .titulo-lanzamiento {
        font-size: 3.5rem;
        color: var(--verde-malp);
        margin: 30px 0;
        letter-spacing: 2px;
    }

    .descripcion-espera {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #444;
        margin-bottom: 40px;
    }

    .linea-tiempo {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        margin-top: 50px;
        color: #999;
        font-weight: bold;
    }

    .punto-activo {
        color: var(--acento-terracota);
        border-bottom: 2px solid var(--acento-terracota);
        padding-bottom: 5px;
    }
</style>

<div class="lanzamiento-container">
    <span class="badge-laboratorio">Fase de Control de Calidad</span>

    <h1 class="titulo-lanzamiento">POMADAS MALP</h1>

    <p class="descripcion-espera">
        Actualmente nos encontramos evaluando la <strong>estabilidad y el rendimiento real</strong> de nuestras nuevas fórmulas.
        En MALP, no lanzamos un producto hasta que confirme su consistencia y eficacia en el uso diario.
    </p>

    <div style="background: #f9fbf9; padding: 35px; border: 1px solid #eee; border-radius: 8px;">
        <h3 style="color: var(--verde-malp); margin-bottom: 15px;">Estándar de Producción</h3>
        <p>Buscamos la fusión perfecta entre oleatos botánicos y ceras naturales, asegurando una textura estable que mantenga todas sus propiedades desde el primer día hasta el último.</p>
    </div>

    <div class="linea-tiempo">
        <span>Formulación ✓</span>
        <span class="punto-activo">Pruebas de Estabilidad</span>
        <span>Lanzamiento</span>
    </div>

    <div style="margin-top: 60px;">
        <a href="/" style="color: var(--verde-malp); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">
            ← Volver a productos disponibles
        </a>
    </div>
</div>