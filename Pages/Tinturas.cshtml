@page "/Tinturas"
@{
    ViewData["Title"] = "Tinturas Madre MALP - Próximamente";
}

<div class="lanzamiento-container">
    <span class="badge-laboratorio">Proceso de Maceración Botánica</span>

    <h1 class="titulo-lanzamiento">TINTURAS MADRE</h1>

    <p class="descripcion-espera">
        La excelencia técnica requiere respeto por los tiempos biológicos. Nuestras tinturas están cumpliendo su etapa de maceración controlada para garantizar la máxima concentración de principios activos.
    </p>

    <div style="background: white; padding: 40px; border-radius: 8px; border: 1px solid #eee; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
        <h2 style="color: var(--acento-terracota); font-weight: bold; margin-bottom: 20px;">Calidad Confirmada.</h2>
        <p style="font-size: 1.1rem; color: #666;">
            "En el desarrollo de nuestras tinturas, la pureza del solvente y la calidad de la materia prima son nuestra prioridad absoluta."
        </p>
    </div>

    <p style="margin-top: 40px; font-weight: bold; color: var(--verde-malp); text-transform: uppercase; letter-spacing: 1px;">
        Próximamente en nuestra colección técnica.
    </p>

    <div style="margin-top: 60px;">
        <a href="/" style="color: var(--verde-malp); text-decoration: none; font-weight: bold; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;">
            ← Ver catálogo actual
        </a>
    </div>
</div>

<style>
    /* Estilos compartidos para coherencia visual de MALP */
    .lanzamiento-container {
        max-width: 800px;
        margin: auto;
        padding: 100px 20px;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .badge-laboratorio {
        background-color: var(--verde-salvia);
        color: white;
        padding: 8px 25px;
        border-radius: 4px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.85rem;
    }

    .titulo-lanzamiento {
        font-size: 3.5rem;
        color: var(--verde-malp);
        margin: 30px 0;
        letter-spacing: 2px;
    }

    .descripcion-espera {
        font-size: 1.25rem;
        line-height: 1.8;
        color: #444;
        margin-bottom: 40px;
    }
</style>