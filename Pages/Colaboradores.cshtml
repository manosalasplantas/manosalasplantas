@page
@{
    ViewData["Title"] = "Colaboradores - MALP";
}

<style>
    body {
        background-color: #fdfaf5;
        font-family: 'Segoe UI', sans-serif;
        padding-top: 50px;
    }

    /* Botón flotante Subir */
    #btnSubir {
        display: none;
        position: fixed;
        bottom: 25px;
        right: 25px;
        z-index: 5500;
        background-color: #1b5e20;
        color: white;
        border: none;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        font-size: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

    .seccion-colaboradores {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
        text-align: center;
    }

    .titulo-principal {
        color: #1b5e20;
        font-size: 2.5rem;
        margin-bottom: 10px;
        font-weight: bold;
    }

    .subtitulo {
        color: #5d4037;
        font-size: 1.2rem;
        margin-bottom: 50px;
        font-style: italic;
    }

    .contenedor-red {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
        justify-content: center;
        align-items: stretch;
    }

    .tarjeta-colaborador {
        background: white;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        flex: 1;
        min-width: 350px;
        max-width: 500px;
        border-top: 6px solid #1b5e20;
        display: flex;
        flex-direction: column;
    }

    .galeria-fotos {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-bottom: 20px;
    }

    .foto-colaborador-img {
        width: 100%;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        background-color: #f9f9f9;
        border: 1px solid #eee;
        cursor: zoom-in;
        transition: 0.3s;
    }

        .foto-colaborador-img:hover {
            opacity: 0.8;
            transform: scale(1.05);
        }

    /* Estilo para imágenes institucionales únicas */
    .foto-unica-institucion {
        width: 100%;
        max-width: 250px;
        height: 150px;
        object-fit: contain;
        margin: 0 auto 20px auto;
        display: block;
        cursor: zoom-in;
    }

    .contenedor-fotos-trebol {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-bottom: 20px;
    }

    .nombre-colaborador {
        color: #1b5e20;
        font-size: 1.8rem;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .descripcion-colaborador {
        color: #444;
        line-height: 1.6;
        font-size: 1.05rem;
        text-align: left;
    }

    /* MODAL ZOOM */
    .modal-zoom {
        display: none;
        position: fixed;
        z-index: 9999;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.9);
        justify-content: center;
        align-items: center;
    }

    .modal-contenido {
        max-width: 90%;
        max-height: 90%;
        border-radius: 10px;
    }

    .cerrar-modal {
        position: absolute;
        top: 20px;
        right: 35px;
        color: #f1f1f1;
        font-size: 40px;
        cursor: pointer;
    }

    .btn-inicio {
        display: inline-block;
        margin-top: 60px;
        padding: 15px 40px;
        background-color: #000;
        color: white !important;
        text-decoration: none;
        border-radius: 8px;
        font-weight: bold;
    }

    .link-instagram {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #E1306C;
        text-decoration: none;
        font-weight: bold;
        margin-bottom: 15px;
        font-size: 1.1rem;
    }
</style>

<button onclick="subirArriba()" id="btnSubir">▲</button>

<div id="modalZoom" class="modal-zoom" onclick="cerrarZoom()">
    <span class="cerrar-modal">&times;</span>
    <img class="modal-contenido" id="imgGrande">
</div>

<div class="seccion-colaboradores">
    <img src="~/Images/logo1.webp" alt="Logo de MALP" style="width: 120px; margin-bottom: 20px;" />

    <h1 class="titulo-principal">Nuestra Red de Apoyo</h1>
    <p class="subtitulo">Personas e instituciones que hacen posible este sueño</p>

    <div class="contenedor-red">

        <article class="tarjeta-colaborador">
            <img src="~/Images/uncu.webp" alt="Logo UNCU" class="foto-unica-institucion" onclick="abrirZoom(this.src)" />
            <h2 class="nombre-colaborador">UNCU</h2>
            <p class="descripcion-colaborador">
                <strong>Unión Nacional de Ciegos del Uruguay</strong><br /><br />
                Organización nacional dedicada a la promoción de derechos y oportunidades para personas con discapacidad visual.
                Su apoyo, facilitando acceso a herramientas tecnológicas, fue clave para el desarrollo de la plataforma digital de <strong>MALP</strong>, permitiéndonos fortalecer nuestra presencia online y profesionalizar nuestro emprendimiento.
            </p>
        </article>

        <article class="tarjeta-colaborador">
            <div class="galeria-fotos">
                <img src="~/Images/amaral.JPEG" alt="Trabajo Richard 1" class="foto-colaborador-img" onclick="abrirZoom(this.src)" />
                <img src="~/Images/amaral1.JPEG" alt="Trabajo Richard 2" class="foto-colaborador-img" onclick="abrirZoom(this.src)" />
                <img src="~/Images/amaral2.JPEG" alt="Trabajo Richard 3" class="foto-colaborador-img" onclick="abrirZoom(this.src)" />
                <img src="~/Images/amaral3.JPEG" alt="Trabajo Richard 4" class="foto-colaborador-img" onclick="abrirZoom(this.src)" />
            </div>
            <h2 class="nombre-colaborador">Richard Amaral</h2>
            <a href="https://www.instagram.com/baobabsolymar" target="_blank" class="link-instagram">
                <i class="fab fa-instagram"></i> @@baobabsolymar
            </a>
            <p class="descripcion-colaborador">
                Carpintero de oficio e incansable colaborador de <strong>MALP</strong>.
                A través de su taller <strong>Baobab</strong> en Solymar, Richard ha sido fundamental,
                aportando su arte en madera para construir este sueño.
            </p>
        </article>

        <article class="tarjeta-colaborador">
            <img src="~/Images/AGORA.WEBP" alt="Programa Ágora" class="foto-unica-institucion" onclick="abrirZoom(this.src)" onerror="this.src='/Images/logo1.webp'" />
            <h2 class="nombre-colaborador">Programa Ágora</h2>
            <p class="descripcion-colaborador">
                Iniciativa de capacitación e intermediación laboral orientada a personas ciegas y con baja visión.
                Su labor se centra en fortalecer la empleabilidad a través de formación específica, acompañamiento técnico y vinculación con el mercado de trabajo.
                <br /><br />
                Brinda soporte a trabajadores y empresas inclusivas en todo el país, promoviendo entornos laborales accesibles y sostenibles. Su compromiso con la inclusión real lo convierte en un aliado estratégico para <strong>MALP</strong>.
            </p>
        </article>

        <article class="tarjeta-colaborador">
            <div class="contenedor-fotos-trebol">
                <img src="~/Images/eltrebol.PNG" alt="Salón El Trébol 1" class="foto-colaborador-img" onclick="abrirZoom(this.src)" style="height: 150px; width: 48%;" />
                <img src="~/Images/eltrebol1.Png" alt="Salón El Trébol 2" class="foto-colaborador-img" onclick="abrirZoom(this.src)" style="height: 150px; width: 48%;" />
            </div>
            <h2 class="nombre-colaborador">Salón El Trébol</h2>
            <p class="descripcion-colaborador">
                Ubicado en el corazón de <strong>Pocitos</strong>, este espacio nos ha abierto gentilmente sus puertas para exhibir y vender nuestros productos naturales, permitiéndonos llegar a más personas cada día junto a <strong>MALP</strong>.
            </p>
        </article>

    </div>

    <a href="/" class="btn-inicio">Volver a la Tienda</a>
</div>

<script>
    function abrirZoom(src) {
        document.getElementById("imgGrande").src = src;
        document.getElementById("modalZoom").style.display = "flex";
    }
    function cerrarZoom() {
        document.getElementById("modalZoom").style.display = "none";
    }
    window.onscroll = function() {
        const btn = document.getElementById("btnSubir");
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btn.style.display = "block";
        } else {
            btn.style.display = "none";
        }
    };
    function subirArriba() {
        window.scrollTo({top: 0, behavior: 'smooth'});
    }
</script>