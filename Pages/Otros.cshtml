@page
@{
    ViewData["Title"] = "Otros Productos - MALP";
}

<style>
    /* (Mismo estilo que Pomadas para coherencia) */
    .contenedor-cinta {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background-color: #1b5e20;
        color: white;
        overflow: hidden;
        white-space: nowrap;
        padding: 12px 0;
        z-index: 5000;
    }

    .texto-animado {
        display: inline-block;
        padding-left: 100%;
        animation: marquee 20s linear infinite;
        font-weight: bold;
        text-transform: uppercase;
    }

    @@keyframes marquee {
        0% {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(-100%, 0);
        }
    }

    body {
        padding-top: 80px;
        background-color: #fdfaf5;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    #btnSubir {
        display: none;
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 5500;
        border: none;
        outline: none;
        background-color: #1b5e20;
        color: white;
        cursor: pointer;
        padding: 15px;
        border-radius: 50%;
        font-size: 20px;
        width: 50px;
        height: 50px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

    .tarjeta-producto {
        border-radius: 15px;
        padding: 20px;
        width: 320px;
        text-align: center;
        background-color: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        border: 1px solid #e0e0e0;
    }

    .contenedor-foto {
        height: 180px;
        margin-bottom: 15px;
        background-color: #f9f9f9;
        border-radius: 8px;
        overflow: hidden;
    }

        .contenedor-foto img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .btn-principal {
        background-color: #1b5e20 !important;
        color: white !important;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
    }

    .btn-volver-final {
        display: block;
        width: 250px;
        margin: 50px auto 20px auto;
        padding: 15px;
        background-color: #000000;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        border-radius: 8px;
    }
</style>

<button onclick="subirArriba()" id="btnSubir">▲</button>

<div class="contenedor-cinta">
    <div class="texto-animado">🌿 COMPLEMENTOS NATURALES — CALIDAD Y BIENESTAR EN CADA PRODUCTO 🚚</div>
</div>

<div id="contenidoPrincipal" style="padding: 20px; max-width: 1200px; margin: 0 auto;">
    <h1 style="color: #1b5e20; text-align: center; margin-bottom: 40px;">Otros Productos</h1>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px;">
        @{
            var listaOtros = new[] {
                new { id = "bolsa_lavanda", n = "Bolsitas de Lavanda", p = 120, img = "bolsa_lavanda.png", r = "Para aromatizar cajones y relajar ambientes." },
                new { id = "aceite_corporal", n = "Aceite Corporal", p = 480, img = "aceite_corporal.png", r = "Nutrición profunda con aromas naturales." }
                };

            foreach (var item in listaOtros)
            {
                <section class="tarjeta-producto">
                    <div class="contenedor-foto">
                        <img src="~/Images/@item.img" alt="@item.n" />
                    </div>
                    <h3 style="color: #1b5e20;">@item.n</h3>
                    <p>@item.r</p>
                    <p style="font-weight: bold; color: #5d4037;">$ @item.p</p>
                    <button class="btn-principal" onclick="gestionarCarrito('agregar', '@item.n', @item.p)">
                        Agregar al Carrito
                    </button>
                </section>
            }
        }
    </div>
    <a href="/" class="btn-volver-final">Volver al Inicio</a>
</div>

<script>
    window.onscroll = function() {
        const btn = document.getElementById("btnSubir");
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) { btn.style.display = "block"; } else { btn.style.display = "none"; }
    };
    function subirArriba() { window.scrollTo({top: 0, behavior: 'smooth'}); }
</script>