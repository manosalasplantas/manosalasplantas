@page
@{
    ViewData["Title"] = "Body Splash - MALP";
}

<style>
    /* Cinta animada */
    .contenedor-cinta {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        background-color: #1b5e20;
        color: white;
        overflow: hidden;
        white-space: nowrap;
        padding: 12px 0;
        z-index: 5000;
    }

    .texto-animado {
        display: inline-block;
        padding-left: 100%;
        animation: marquee 20s linear infinite;
        font-weight: bold;
        text-transform: uppercase;
    }

    @Html.Raw("@") keyframes marquee {
        0% {
            transform: translate(0, 0);
        }

        100% {
            transform: translate(-100%, 0);
        }
    }

    body {
        padding-top: 70px;
        background-color: #fdfaf5;
        font-family: 'Segoe UI', Arial, sans-serif;
    }

    /* Botón flotante Subir */
    #btnSubir {
        display: none;
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 5500;
        border: none;
        outline: none;
        background-color: #1b5e20;
        color: white;
        cursor: pointer;
        padding: 15px;
        border-radius: 50%;
        font-size: 20px;
        width: 50px;
        height: 50px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        #btnSubir:hover {
            background-color: #2e7d32;
            transform: scale(1.1);
        }

    .tarjeta-producto {
        border-radius: 15px;
        padding: 20px;
        width: 320px;
        text-align: center;
        background-color: #ffffff;
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .reseña-visible {
        font-size: 0.9rem;
        color: #555;
        font-style: italic;
        margin: 10px 0;
        min-height: 60px;
        line-height: 1.3;
    }

    .caja-precios-sensorial {
        background-color: #f5f5dc;
        border: 1px solid #d2b48c;
        border-radius: 10px;
        padding: 12px;
        margin: 15px 0;
    }

    .opcion-talle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
        cursor: pointer;
        color: #5d4037;
        font-weight: bold;
    }

    .btn-principal {
        background-color: #1b5e20 !important;
        color: white !important;
        border: none;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        width: 100%;
        font-size: 1.1rem;
        transition: 0.3s;
    }

        .btn-principal:hover {
            background-color: #2e7d32 !important;
            transform: scale(1.02);
        }

    .btn-volver-final {
        display: block;
        width: 250px;
        margin: 50px auto 20px auto;
        padding: 15px;
        background-color: #000000;
        color: #ffffff !important;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        border-radius: 8px;
        transition: 0.3s;
    }

    #visorFotos {
        display: none;
        position: fixed;
        z-index: 6000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(255, 255, 255, 0.98);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    #imgVisor {
        max-width: 80%;
        max-height: 50%;
        border-radius: 15px;
    }
</style>

<button onclick="subirArriba()" id="btnSubir" title="Subir al inicio">▲</button>

<div class="contenedor-cinta">
    <div class="texto-animado">
        FRAGANCIAS QUE PERFUMAN TU DÍA — M A L P — ¡ENVIOS A TODO URUGUAY! 🚚
    </div>
</div>

<div id="contenidoPrincipal" style="padding: 20px; max-width: 1200px; margin: 30px auto 0 auto;">
    <div style="text-align: center; margin-bottom: 20px;">
        <img src="/Images/logo1.webp" alt="Logotipo MALP" style="width: 200px;" />
    </div>

    <h1 style="color: #1b5e20; text-align: center; margin-bottom: 40px;">Catálogo de Body Splash MALP</h1>

    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 30px;">
        @{
            var listaBody = new[] {
                new { id = "violetas", n = "Violetas", c = "#e1bee7", img = "Violetas.png", r = "Un aroma floral suave y nostálgico que evoca la frescura del rocío matutino." },
                new { id = "marina", n = "Marina", c = "#bbdefb", img = "Marina.png", r = "Sensación de brisa oceánica y libertad; una fragancia fresca y revitalizante." },
                new { id = "rosas", n = "Rosas", c = "#f8bbd0", img = "Rosas.png", r = "El clásico romance de los pétalos de rosa frescos, elegant y femenino." },
                new { id = "jazmin", n = "Jazmín", c = "#f1f8e9", img = "Jazmin.png", r = "Aroma dulce e intenso que captura la esencia pura de los jardines blancos." },
                new { id = "dama_noche", n = "Dama de la Noche", c = "#d1c4e9", img = "Dama de la Noche.png", r = "Fragancia misteriosa y envolvente que florece con intensidad en la oscuridad." },
                new { id = "carolina_h", n = "Carolina Herrera", c = "#f5f5f5", img = "Carolina Herrera.png", r = "Inspiración sofisticada y moderna, ideal para distinción diaria." },
                new { id = "anais_anais", n = "Anaís Anaís", c = "#fff9c4", img = "Anais Anais.png", r = "Un ramo de flores blancas delicadas, romántico y suave como una caricia." },
                new { id = "mango", n = "Mango", c = "#ffe0b2", img = "Mango.png", r = "Explosión tropical y jugosa que llena tu día de energía frutal." },
                new { id = "amber_oud", n = "Amber Oud", c = "#ffecb3", img = "Amber Oud.png", r = "Notas amaderadas y resinas cálidas para una presencia exótica y duradera." },
                new { id = "lavanda_poquet", n = "Lavanda Poquet", c = "#ede7f6", img = "lavanda Poquet.png", r = "La pureza de la lavanda silvestre para brindar calma y serenidad." },
                new { id = "melon_dulce", n = "Melón Dulce", c = "#e8f5e9", img = "Melon Dulce.png", r = "Refrescante y alegre, captura la esencia más dulce del melón." },
                new { id = "durazno", n = "Durazno", c = "#fff3e0", img = "Durazno.png", r = "Aroma aterciopelado y dulce que deja una estela suave y encantadora." },
                new { id = "lavanda_vainilla", n = "Lavanda Vainilla", c = "#f3e5f5", img = "lavanda Vainilla.png", r = "Equilibrio entre la relajación de la lavanda y la calidez de la vainilla." },
                new { id = "aquagio", n = "Aqua Di Gio", c = "#e0f2f1", img = "Aqua Di Gio.png", r = "Frescura cítrica y notas acuáticas inspiradas en el mar." },
                new { id = "boss", n = "Boss Intense", c = "#cfd8dc", img = "Boss Intense.png", r = "Fragancia con carácter y notas amaderadas intensas." },
                new { id = "invictus", n = "Invictus", c = "#cfd8dc", img = "Invictus.png", r = "Fragancia heroica que combina frescura marina con maderas triunfantes." },
                new { id = "mburucuya", n = "Mburucuyá", c = "#f9fbe7", img = "Mburucuyá.png", r = "Aroma exótico y relajante de la flor de la pasión, dulce y silvestre." }
            };

            foreach (var item in listaBody)
            {
                <section class="tarjeta-producto" style="border: 2px solid @item.c;">
                    <button type="button" onclick="abrirVisor('@item.img', '@item.n', '@item.r')" style="border:none; background:none; cursor:pointer;" aria-label="Ampliar @item.n">
                        <div style="height: 180px; margin-bottom: 10px; background-color: #f9f9f9; border-radius: 8px; overflow: hidden;">
                            <img src="/Images/@item.img" alt="Envase de @item.n" style="width: 100%; height: 100%; object-fit: contain;" onerror="this.src='/Images/logo1.webp'" />
                        </div>
                    </button>

                    <h3 style="font-size: 1.4rem; color: #1b5e20; margin:0;">@item.n</h3>
                    <div class="reseña-visible">@item.r</div>

                    <div class="caja-precios-sensorial">
                        <label class="opcion-talle">
                            <span><input type="radio" name="p-@item.id" value="100ml|290" checked> 100ml</span>
                            <span>UYU 290</span>
                        </label>
                        <label class="opcion-talle">
                            <span><input type="radio" name="p-@item.id" value="50ml|180"> 50ml</span>
                            <span>UYU 180</span>
                        </label>
                    </div>

                    <button type="button" class="btn-principal" onclick="agregarConOpcion('@item.id', '@item.n', '@item.img')">
                        Agregar al Carrito
                    </button>
                </section>
            }
        }
    </div>

    <a href="/#catalogo" class="btn-volver-final">Volver al Catálogo</a>
</div>

<div id="visorFotos" role="dialog" aria-modal="true" onclick="if(event.target == this) cerrarVisor()">
    <button type="button" onclick="cerrarVisor()" style="position: absolute; top: 20px; right: 30px; font-size: 30px; cursor:pointer; background:none; border:none; color:#1b5e20;">✕</button>
    <img id="imgVisor" src="" alt="Imagen ampliada" onerror="this.src='/Images/logo1.webp'">
    <div id="resenaFragancia" style="color: #1b5e20; font-size: 1.3rem; margin-top: 20px; max-width: 80%; font-weight: 500; text-align: center;"></div>
</div>

<script>
    function agregarConOpcion(id, nombre, imagen) {
        const opciones = document.getElementsByName("p-" + id);
        let seleccion = "";

        for (const op of opciones) {
            if (op.checked) {
                seleccion = op.value;
                break;
            }
        }

        const [tamano, precio] = seleccion.split('|');

        let carrito = JSON.parse(localStorage.getItem('carritoMALP')) || [];
        carrito.push({
            nombre: `Body Splash ${nombre} (${tamano})`,
            precio: parseInt(precio),
            imagen: imagen
        });
        localStorage.setItem('carritoMALP', JSON.stringify(carrito));

        if (typeof actualizarContador === 'function') {
            actualizarContador();
        }

        alert(`¡${nombre} (${tamano}) agregado al carrito!`);
    }

    window.onscroll = function() {
        const btn = document.getElementById("btnSubir");
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btn.style.display = "block";
        } else {
            btn.style.display = "none";
        }
    };

    function subirArriba() {
        window.scrollTo({top: 0, behavior: 'smooth'});
    }

    function abrirVisor(imgSrc, nombre, resena) {
        document.getElementById("imgVisor").src = "/Images/" + imgSrc;
        document.getElementById("imgVisor").alt = "Foto ampliada de " + nombre;
        document.getElementById("resenaFragancia").innerText = resena;
        document.getElementById("visorFotos").style.display = "flex";
    }

    function cerrarVisor() {
        document.getElementById("visorFotos").style.display = "none";
    }
</script>